{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": "../..",
    "paths": {
      "@/domain/*": ["packages/shared/src/domain/*"],
      "@/utils/*": ["packages/shared/src/utils/*"],
      "@/battle/*": ["packages/shared/src/battle/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
